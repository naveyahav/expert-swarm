# =============================================================================
# ExpertSwarm — environment variable template
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram bot (required to run interfaces/telegram_bot.py)
# Get your token from @BotFather on Telegram.
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Credit backend
# Options: mock (default, in-memory) | sqlite (persistent) | stripe
# -----------------------------------------------------------------------------
EXPERTSWARM_BACKEND=sqlite

# Path to the SQLite database file (used when EXPERTSWARM_BACKEND=sqlite or stripe).
# In Docker this is automatically set to /data/credits.db via docker-compose.yml.
EXPERTSWARM_DB_PATH=data/credits.db

# -----------------------------------------------------------------------------
# Stripe payment integration (required only when EXPERTSWARM_BACKEND=stripe)
# https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Model override (optional — defaults to microsoft/phi-2)
# -----------------------------------------------------------------------------
EXPERTSWARM_MODEL_ID=microsoft/phi-2

# -----------------------------------------------------------------------------
# Web UI port (optional — defaults to 8501)
# -----------------------------------------------------------------------------
WEB_PORT=8501
